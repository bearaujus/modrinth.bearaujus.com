---
import type { Mod } from '../data/mods';
import type { Stat } from '../lib/modrinth';
import { MC_VERSION, LOADER } from '../data/mods';

interface Props {
  mod: Mod;
  stat: Stat;
  index: number;
}
const { mod, stat, index } = Astro.props;
const flip = index % 2 === 1;
const num = String(index + 1).padStart(2, '0');
const href = `https://modrinth.com/mod/${mod.slug}`;
const fmt = (n: number) => n.toLocaleString('en-US');
---

<article
  class={`show ${flip ? 'show--flip' : ''}`}
  style={`--accent: var(--${mod.accent})`}
  data-reveal
>
  <div class="show-copy">
    <div class="show-kicker">
      <span class="show-num">{num}</span>
      <span class="eyebrow">{mod.categories[0]}</span>
    </div>
    <h3 class="show-name">{mod.name}</h3>
    <p class="show-tag">{mod.tagline}</p>

    <ul class="show-list">
      {mod.bullets.map((b) => <li>{b}</li>)}
    </ul>

    <div class="show-chips">
      <span class="chip"><strong>{LOADER}</strong></span>
      <span class="chip">MC <strong>{MC_VERSION}</strong></span>
      <span class="chip">server <strong>{mod.env.server}</strong></span>
      <span class="chip">client <strong>{mod.env.client}</strong></span>
    </div>

    <div class="show-foot">
      <a class="btn btn-primary" href={href} target="_blank" rel="noopener noreferrer">
        Get on Modrinth ↗
      </a>
      <span class="show-metric">
        <strong>{fmt(stat.downloads)}</strong> downloads ·
        <strong>{fmt(stat.followers)}</strong> followers
      </span>
    </div>
  </div>

  <div class="show-media">
    <div class="badge">
      <img
        class="badge-icon"
        src={`/mods/${mod.slug}/icon.png`}
        alt={`${mod.name} icon`}
        width="320"
        height="320"
        loading="lazy"
      />
    </div>
  </div>
</article>

<style>
  .show {
    display: grid;
    gap: clamp(1.5rem, 1rem + 4vw, 3.5rem);
    align-items: center;
    padding-block: clamp(2.5rem, 1.5rem + 4vw, 4.5rem);
    border-top: 1px solid var(--line-soft);
  }
  @media (min-width: 900px) {
    .show {
      grid-template-columns: 1.05fr 0.95fr;
    }
    .show--flip .show-copy {
      order: 2;
    }
  }

  .show-kicker {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }
  .show-num {
    font-family: var(--font-pixel);
    font-size: 0.85rem;
    color: var(--accent);
  }
  .show-name {
    margin-top: 0.9rem;
    font-size: var(--step-3);
  }
  .show-tag {
    margin-top: 0.8rem;
    color: var(--muted);
    font-size: var(--step-1);
    max-width: 40ch;
  }
  .show-list {
    margin-top: 1.4rem;
    display: grid;
    gap: 0.7rem;
  }
  .show-list li {
    position: relative;
    padding-left: 1.5rem;
    color: var(--ink);
    font-size: var(--step--1);
    line-height: 1.55;
  }
  .show-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 7px;
    height: 7px;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
  }

  .show-chips {
    margin-top: 1.6rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .show-foot {
    margin-top: 1.8rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.4rem;
  }
  .show-metric {
    font-size: 0.8rem;
    color: var(--muted);
  }
  .show-metric strong {
    color: var(--ink);
    font-family: var(--font-mono);
  }

  /* ---- icon-only media: the icon fills the frame ---- */
  .show-media {
    display: flex;
    justify-content: center;
  }
  .badge {
    position: relative;
    width: 100%;
    max-width: 380px;
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    padding: clamp(0.9rem, 0.4rem + 2vw, 1.4rem);
    border-radius: var(--radius);
    overflow: hidden;
    /* a soft accent wash so transparent icon edges sit on something */
    background:
      radial-gradient(70% 70% at 50% 42%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 72%),
      var(--panel);
    box-shadow: 0 0 0 1px var(--line);
  }
  .badge::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: var(--accent);
  }
  .badge-icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 14px;
    filter: drop-shadow(0 22px 38px rgba(0, 0, 0, 0.6));
  }
</style>
